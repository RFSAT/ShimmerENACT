<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base theme uses AppCompat (always available). Material3 theming is
         applied entirely in Compose via ShimmerENACTTheme — no XML M3 needed. -->
    <style name="Theme.ShimmerENACT" parent="Theme.AppCompat.DayNight.NoActionBar">
        <!-- statusBarColor / navigationBarColor deprecated in Android 15 (API 35).
             Bar appearance is set at runtime by enableEdgeToEdge() in MainActivity. -->
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowBackground">@color/enact_dark</item>
    </style>

    <style name="Theme.ShimmerENACT.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#082C28</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_icon</item>
        <item name="windowSplashScreenIconBackgroundColor">#43AF81</item>
        <item name="postSplashScreenTheme">@style/Theme.ShimmerENACT</item>
    </style>
</resources>
