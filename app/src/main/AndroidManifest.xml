<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Bluetooth Classic permissions -->
    <uses-permission android:name="android.permission.BLUETOOTH"
        android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN"
        android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN"
        android:usesPermissionFlags="neverForLocation" />

    <!-- Location permissions.
         On Android 12+ (API 31+) both FINE and COARSE must be declared together;
         the user may choose to grant only COARSE. The app can function with COARSE
         for Bluetooth scanning; FINE is used for GPS tagging during recording. -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- Storage: write access required only on Android 9 (API 28) and below.
         On API 29+ the app uses getExternalFilesDir() which needs no permission. -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <!-- Internet access — required for OpenStreetMap tile loading in RecordingViewerScreen -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Vibrate for alerts -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Foreground service for background-safe recording sessions (Android 16 policy).
         The connectedDevice type reflects streaming from a paired Bluetooth sensor. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE" />
    <!-- Runtime notification permission (API 33+) for the recording progress notification -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- BT classic hardware feature -->
    <uses-feature
        android:name="android.hardware.bluetooth"
        android:required="true" />

    <!-- Declare support for all screen sizes including tablets, foldables, ChromeOS -->
    <supports-screens
        android:smallScreens="true"
        android:normalScreens="true"
        android:largeScreens="true"
        android:xlargeScreens="true"
        android:resizeable="true"
        android:anyDensity="true" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.ShimmerENACT"
        android:hardwareAccelerated="true"
        android:enableOnBackInvokedCallback="true">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:resizeableActivity="true"
            android:configChanges="orientation|screenSize|screenLayout|smallestScreenSize|density|keyboard|keyboardHidden|navigation"
            android:theme="@style/Theme.ShimmerENACT.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Foreground service keeping recording alive while backgrounded -->
        <service
            android:name=".service.RecordingService"
            android:exported="false"
            android:foregroundServiceType="connectedDevice" />

        <!-- File provider for sharing CSVs -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
